# Copy thành .env.local rồi điền giá trị thực (không commit file .env.local)

# Lấy từ Neon Dashboard → Connection Details → Connection string
POSTGRES_URL=postgresql://user:pass@ep-xxx.us-east-2.aws.neon.tech/neondb?sslmode=require

# Chuỗi bí mật để ký JWT — đặt ít nhất 32 ký tự ngẫu nhiên
JWT_SECRET=replace-with-a-long-random-secret-string-here

# Dùng cho /api/setup route — đặt chuỗi bất kỳ, dùng đúng 1 lần
SETUP_SECRET=replace-with-any-secret
